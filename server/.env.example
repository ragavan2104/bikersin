# Firebase Configuration
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# JWT Secret (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="your-super-secure-256-bit-jwt-secret-here"

# Node Environment
NODE_ENV=development

# CORS Origins (your frontend domains - update for production)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,https://bikers-tenant.vercel.app,https://bikers-superadmin.vercel.app"

# Port (for local development, Vercel handles this automatically)
PORT=5000

# Rate Limiting (Optional - for Upstash Redis in production)
# UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# 📝 FIREBASE SETUP:
# 1. Go to https://console.firebase.google.com
# 2. Create new project
# 3. Enable Firestore Database
# 4. Go to Project Settings → Service accounts
# 5. Generate new private key (JSON)
# 6. Extract projectId, client_email, and private_key from the JSON
# 7. Replace the values above with your Firebase credentials
